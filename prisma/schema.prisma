generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum AlbumPrivacy {
  PRIVATE
  UNLISTED
  PASSWORD
  PUBLIC
}

enum MediaType {
  IMAGE
  VIDEO
}

model User {
  id                 String              @id @default(cuid())
  name               String?
  email              String              @unique
  emailVerified      DateTime?
  password           String?
  provider           String?
  image              String?
  role               UserRole            @default(USER)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  accounts           Account[]
  sessions           Session[]
  cloudinarySettings CloudinarySettings?
  albums             Album[]
  otpCodes           OtpCode[]
  resetTokens        PasswordResetToken[]
}

model CloudinarySettings {
  id                 String   @id @default(cuid())
  userId             String   @unique
  cloudName          String
  apiKey             String
  encryptedApiSecret String
  connected          Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Album {
  id           String       @id @default(cuid())
  userId       String
  title        String
  slug         String
  description  String?
  coverImage   String?
  privacy      AlbumPrivacy @default(PRIVATE)
  passwordHash String?
  shareToken   String       @unique @default(cuid())
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  media        Media[]

  @@unique([userId, slug])
  @@index([userId, createdAt])
}

model Media {
  id                 String    @id @default(cuid())
  albumId            String
  cloudinaryPublicId String
  imageUrl           String
  secureUrl          String?
  mediaType          MediaType
  category           String    @default("Wedding")
  order              Int       @default(0)
  width              Int?
  height             Int?
  bytes              Int?
  duration           Float?
  createdAt          DateTime  @default(now())
  album              Album     @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@index([albumId, order])
}

model OtpCode {
  id        String   @id @default(cuid())
  userId    String
  codeHash  String
  purpose   String   @default("EMAIL_VERIFY")
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose, expiresAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
