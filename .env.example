# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Auth.js / NextAuth
AUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Used to encrypt each user's Cloudinary API secret at rest.
# Any long random string works; keep it stable across deploys.
CLOUDINARY_ENCRYPTION_KEY="replace-with-32-plus-random-characters"

# Optional production mail sender for OTP and reset links.
MAIL_FROM="Aureole Albums <noreply@example.com>"
